            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "comments": {
            "maxLength": 2000,
            "minLength": 1,
            "type": "string"
          },
          "recommendation": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
