        "required": [
          "applicationId",
          "comments",
          "recommendation"
        ],
        "type": "object",
        "properties": {
          "applicationId": {
            "type": "integer",
            "format": "int32"
          },
          "technicalScore": {
            "maximum": 10,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "communicationScore": {
            "maximum": 10,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
          "problemSolvingScore": {
            "maximum": 10,
            "minimum": 0,
            "type": "integer",
            "format": "int32"
          },
